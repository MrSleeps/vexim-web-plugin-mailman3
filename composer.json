{
    "name": "mrsleeps/vexim-web-plugin-mailman3",
    "description": "Mailman 3 plugin for the VExim Web UI",
    "keywords": [
        "MrSleeps",
        "laravel",
        "filamentphp",
        "filament",
        "filament-plugin",
        "vexim-web-plugin-mailman3"
    ],
    "homepage": "https://github.com/mrsleeps/vexim-web-plugin-mailman3",
    "support": {
        "issues": "https://github.com/mrsleeps/vexim-web-plugin-mailman3/issues",
        "source": "https://github.com/mrsleeps/vexim-web-plugin-mailman3"
    },
    "license": "GPL-3.0-only",
    "authors": [
        {
            "name": "Mr Sleeps",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4",
        "filament/filament": "^5.0",
        "spatie/laravel-package-tools": "^1.15.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.7|^4.0",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0",
        "pestphp/pest-plugin-livewire": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "VEximweb\\Plugin\\VEximMailman3\\": "src/",
            "VEximweb\\Plugin\\VEximMailman3\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "VEximweb\\Plugin\\VEximMailman3\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "phpstan analyse",
        "lint": "pint",
        "test": "pest",
        "test:lint": "pint --test"
    },
    "extra": {
        "laravel": {
            "providers": [
                "VEximweb\\Plugin\\VEximMailman3\\VEximMailman3ServiceProvider"
            ],
            "aliases": {
                "VEximMailman3": "VEximweb\\Plugin\\VEximMailman3\\Facades\\VEximMailman3"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
